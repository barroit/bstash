{
   "files.associations": {
      "**/Makefile.*": "makefile",
      "**/*.awk": "plaintext",
   },
   "search.exclude": {
      "**/openssl": true,
      "**/sqlite": true,
      "**/kconfiglib": true,
      "**/tapview": true,
   },
   "git.ignoredRepositories": [
      "kconfiglib",
      "openssl",
      "sqlite",
      "tapview",
   ],
   "C_Cpp.default.includePath": [
      "${workspaceFolder}/include",
      "${workspaceFolder}/t/include",
      "${workspaceFolder}/sqlite/build",
      "${workspaceFolder}/openssl/include",
      "${workspaceFolder}/openssl/build/include",
   ],
   "C_Cpp.default.forcedInclude": [
      "${workspaceFolder}/include/generated/build.h",
      "${workspaceFolder}/include/generated/commands.h",
      "${workspaceFolder}/include/generated/config.h",
      "${workspaceFolder}/include/generated/features.h",
      "${workspaceFolder}/include/generated/unitest.h",
   ],
}
