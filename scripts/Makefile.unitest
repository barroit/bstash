ifneq ($(filter $(objtree)/t/unit/run $(objtree)/t/unit/%.run,$(MAKECMDGOALS)),)
  MAKEFLAGS += -s
endif

CFLAGS += -iquote t/unit/include

ut-lib-y := $(objtree)/t/unit/lib/main.o
ut-unit-y := $(objtree)/t/unit/log.o \
	     $(objtree)/t/unit/strbuf_alloc.o \
	     $(objtree)/t/unit/strbuf_prealloc.o

ut-y := $(ut-unit-y:.o=.run)

include t/unit/Makefile.deps

-include $(ut-unit-y:.o=.d)

.PHONY: $(objtree)/t/unit/run

$(objtree)/t/unit/run: $(ut-y)

$(ut-y):

$(objtree)/t/unit/%.bin: $(objtree)/t/unit/%.o $(ut-lib-y) $(lib-y) $(link-y)
	mkdir -p $(@D)
	$(CC) -fuse-ld=$(LD) $(LDFLAGS) $^ -o $@

$(ut-unit-y):

$(ut-lib-y):

$(objtree)/t/unit/%.run: $(objtree)/t/unit/%.bin
	printf '%s\n' $(patsubst %.run,%.pass,$(filter %.run,$^)) >$<.deps
	rm -f $(patsubst %.bin,%.pass,$<)
	printf '\n== %s\n' $<
	env time -p $< $<.deps 2>$<.err | ./tapview/tapview && \
	touch $(patsubst %.bin,%.pass,$<) || true
	printf '\n'
	cat $<.err
